generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Url {
  id          Int      @id @default(autoincrement())
  originalUrl String   
  shortCode   String?   @unique
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([shortCode])
  @@index([originalUrl])
}